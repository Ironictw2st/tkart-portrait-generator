# Normalize line endings: store text as LF in the repo, check out native on each OS.
* text=auto eol=lf

# Windows batch/PowerShell scripts must keep CRLF to run reliably.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat model weights / binaries as binary (never line-ending munged or diffed).
*.safetensors binary
*.ckpt binary
*.pt binary
*.bin binary
*.onnx binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.tar.gz binary
